# Copy this to .env and fill in your values
# .env is gitignored — never commit secrets

# Authentication (one of these is required)
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: GitHub token (auto-detected from gh cli in most cases)
GITHUB_TOKEN=

# Research config (all optional, defaults shown)
MAX_ITERATIONS=50
RESEARCH_MODEL=claude-opus-4-5
HARD_RESEARCH_MODEL=claude-opus-4-5
NO_JUDGES=1
POLL_INTERVAL=60
POLL_MAX=7200

# Backend config (optional)
ROOT_DIR=
